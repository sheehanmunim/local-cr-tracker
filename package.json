{
  "name": "local-cr-tracker",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "local": "node scripts/local-dev.mjs",
    "setup": "node scripts/local-dev.mjs --setup-only",
    "dev": "convex dev --start \"next dev --webpack\"",
    "dev:local": "cross-env CONVEX_AGENT_MODE=anonymous convex dev --local-backend-version precompiled-2026-06-09-b6aaa1a --start \"next dev --webpack\"",
    "dev:private-local": "convex dev --env-file .convex/private-local.env --start \"next dev --webpack\"",
    "convex:local": "cross-env CONVEX_AGENT_MODE=anonymous convex dev",
    "codegen": "node scripts/codegen.mjs",
    "backup:now": "node scripts/shared-backup.mjs now",
    "backup:verify": "node scripts/shared-backup.mjs verify",
    "backup:restore": "node scripts/shared-backup.mjs restore",
    "prebuild": "npm run codegen",
    "build": "next build",
    "models": "node scripts/local-dev.mjs --models-only",
    "models:r2": "node scripts/r2-model-mirror.mjs setup",
    "models:r2:upload": "node scripts/r2-model-mirror.mjs upload",
    "models:r2:env": "node scripts/r2-model-mirror.mjs env",
    "prestart": "node scripts/local-dev.mjs --models-only",
    "start": "next start",
    "lint": "eslint .",
    "test:workflow": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON --test tests/ecc-workflow-intent.test.mjs"
  },
  "dependencies": {
    "@convex-dev/better-auth": "^0.12.4",
    "@huggingface/transformers": "^4.2.0",
    "@next/env": "16.2.7",
    "@radix-ui/react-dropdown-menu": "^2.1.4",
    "@radix-ui/react-icons": "^1.3.2",
    "@radix-ui/react-slot": "^1.1.1",
    "@radix-ui/react-toggle": "^1.1.1",
    "@radix-ui/react-toggle-group": "^1.1.1",
    "better-auth": "~1.6.15",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "convex": "^1.41.0",
    "kokoro-js": "^1.2.1",
    "lucide-react": "^0.544.0",
    "next": "^16.1.5",
    "next-themes": "^0.4.4",
    "npm-run-all2": "^5.0.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwind-merge": "^2.6.0",
    "tailwindcss-animate": "^1.0.7"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "cross-env": "^10.1.0",
    "eslint": "^9",
    "eslint-config-next": "^16.0.10",
    "postcss": "^8",
    "prettier": "3.6.2",
    "tailwindcss": "^3.4.1",
    "typescript": "^5",
    "wrangler": "^4.50.0"
  }
}
