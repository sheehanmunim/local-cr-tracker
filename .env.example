LOCAL_MODEL_PROFILE=auto
# Optional: pin exact models to bypass adaptive local selection.
# OLLAMA_MODEL=qwen3.5:4b
# OLLAMA_VOICE_MODEL=gemma3:4b
# OLLAMA_VISION_MODEL=gemma3:4b
OLLAMA_KEEP_ALIVE=30m
OLLAMA_BASE_URL=http://127.0.0.1:11434
# Optional: import GGUF artifacts from local cache or a mirror.
# Put files in this folder, or set the mirror base URL to an R2/S3/GitHub release URL.
OLLAMA_MODEL_ARTIFACT_DIR=.cache/ollama-models
# OLLAMA_MODEL_MIRROR_BASE_URL=https://models.fourechelon.com/ecc
# Keep this enabled for corporate laptops that cannot reach Ollama's registry.
# Set to 0 only on maintainer machines that are allowed to run `ollama pull`.
OLLAMA_DISABLE_REGISTRY_FALLBACK=1
# OLLAMA_MODEL_DOWNLOAD_TIMEOUT_MS=1800000
# Maintainer-only Cloudflare R2 upload settings.
R2_MODEL_BUCKET=ecc-local-models
R2_MODEL_PREFIX=ecc
# R2_MODEL_DOMAIN=models.fourechelon.com
KOKORO_MODEL=onnx-community/Kokoro-82M-v1.0-ONNX
KOKORO_VOICE=af_heart
KOKORO_DTYPE=q8
KOKORO_DEVICE=cpu
KOKORO_SPEED=0.97
# Set to 1 after the Kokoro model has been cached locally.
KOKORO_OFFLINE=0
LOCAL_STT_MODEL=onnx-community/moonshine-tiny-ONNX
LOCAL_STT_DTYPE=q8
LOCAL_STT_DEVICE=cpu
# Set to 1 after the Moonshine STT model has been cached locally.
LOCAL_STT_OFFLINE=0
BETTER_AUTH_URL=http://localhost:3000
NEXT_PUBLIC_BETTER_AUTH_URL=http://localhost:3000
BETTER_AUTH_SECRET=replace-with-a-local-random-secret
